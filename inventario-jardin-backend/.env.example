NODE_ENV=development
PORT=3001
APP_NAME="Inventario Jardín"
API_VERSION=v1

DATABASE_URL="postgresql://USUARIO:PASSWORD@localhost:5432/inventario_jardin?schema=public"

JWT_ACCESS_SECRET=genera_con_openssl_rand_base64_64
JWT_REFRESH_SECRET=genera_con_openssl_rand_base64_64
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=12
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10

LOG_LEVEL=debug
LOG_FILE_PATH=./logs
